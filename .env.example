# ============================================================
#  Configuración del modelo — elige UN proveedor
#  Copia este archivo a .env y pon tu API key.
# ============================================================

# --- Opción por defecto: Gemini (GRATIS) ---
MODEL_PROVIDER=google_genai
MODEL_NAME=gemini-2.0-flash
GOOGLE_API_KEY=pega_tu_key_de_google_ai_studio

# --- Opcional: OpenAI (requiere créditos, aprox. $5) ---
# MODEL_PROVIDER=openai
# MODEL_NAME=gpt-4o-mini
# OPENAI_API_KEY=pega_tu_key_de_openai

# --- Opcional: OpenRouter (créditos, muchos modelos) ---
# MODEL_PROVIDER=openrouter
# MODEL_NAME=meta-llama/llama-3.3-70b-instruct
# OPENROUTER_API_KEY=pega_tu_key_de_openrouter

# ============================================================
#  Práctica 3 — servicio externo (configura SOLO el de tu opción)
# ============================================================

# Opción A — Notion (token de integración + id de la base de datos)
# NOTION_TOKEN=
# NOTION_DATABASE_ID=

# Opción B — Todoist (token de API)
# TODOIST_TOKEN=

# Opción C — API pública (ejemplo: OpenWeather)
# OPENWEATHER_API_KEY=
